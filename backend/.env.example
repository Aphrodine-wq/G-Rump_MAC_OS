# OpenRouter API key (required for chat proxy). Get one at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-...

# JWT secret for session tokens. REQUIRED in production: use a random 32+ character string.
JWT_SECRET=your-random-secret-at-least-32-chars

# Google OAuth Client IDs for Sign-In. Create at https://console.cloud.google.com/apis/credentials
# Use comma-separated list for both iOS and macOS client IDs (e.g. iOS_ID, macOS_ID)
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com,yyy.apps.googleusercontent.com

# Production: set to restrict CORS (comma-separated origins).
# Include both the website and any native app origins.
CORS_ORIGIN=https://www.g-rump.com,https://g-rump.com

# Public-facing URL for Stripe redirect pages (billing success/cancel, portal return).
# In production this should be the website where users manage billing.
APP_URL=https://www.g-rump.com

# Stripe keys (required for billing). Get from https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_TEAM=price_...
# STRIPE_PRICE_CREDITS_1K=price_...
# STRIPE_PRICE_CREDITS_5K=price_...
# STRIPE_PRICE_CREDITS_20K=price_...

# Optional: port (default 3042)
# PORT=3042

# Optional: SQLite path (default: backend/data/grump.db)
# DATABASE_PATH=./data/grump.db
